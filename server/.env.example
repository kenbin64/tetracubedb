# TetracubeDB Environment Configuration
# Copy to .env and fill in values

# Port the server listens on
PORT=4747

# Absolute path to the persistent data directory (OUTSIDE the app dir — survives deploys)
DATA_DIR=/var/lib/tetracubedb

# Explicit DB path (overrides DATA_DIR if set)
# DB_PATH=/var/lib/tetracubedb/tetracube.db

# Comma-separated origins allowed by CORS
ALLOWED_ORIGINS=https://kensgames.com,https://www.kensgames.com,https://tetracubedb.com

# Node environment
NODE_ENV=production
