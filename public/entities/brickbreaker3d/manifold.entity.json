{
  "entity": "brickbreaker3d",
  "name": "BrickBreaker 3D",
  "tagline": "3D brick breaking with golden ratio physics and layered geometry",
  "icon": "🧱",
  "version": "1.0.0",
  "status": "production",
  "dimension": {
    "x": 2,
    "y": 22,
    "z": 44,
    "_note": "z = x*y = 2 players avg * 22 min avg = 44; D4 PLANE on gyroid"
