      "level",
      "score",
      "lives",
      "ballPosition",
      "brickGrid"
    ]
  },
  "source": {
    "portal": "kensgames.com",
    "path": "brickbreaker3d/",
    "manifold": "brickbreaker3d/manifold.game.json"
  }
